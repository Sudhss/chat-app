NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://flux_user:flux_pass@localhost:5432/flux_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_here_use_openssl
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_here_use_openssl
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookie
COOKIE_SECRET=change_me_cookie_secret_min_32_chars_here

# Client
CLIENT_URL=http://localhost:3000

# S3 / MinIO
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=flux-media
S3_ENDPOINT=http://localhost:9000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Config
BCRYPT_ROUNDS=12
MAX_FILE_SIZE_MB=25
